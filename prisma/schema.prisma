generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  PROJECT_MANAGER
  CLUSTER_HEAD
  VICE_PRESIDENT
  HEAD_OF_STORES
  HEAD_OF_PROCUREMENT
  PROCUREMENT_TEAM_MEMBER
  STORE_MANAGER
}

enum IndentStatus {
  DRAFT
  PENDING_APPROVAL
  PARTIALLY_APPROVED
  APPROVED
  REJECTED
  ASSIGNED
  RFQ_SENT
  QUOTES_RECEIVED
  PO_CREATED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum ApprovalAction {
  APPROVED
  REJECTED
}

enum RFQStatus {
  DRAFT
  SENT
  QUOTES_RECEIVED
  CLOSED
  CANCELLED
}

enum QuoteStatus {
  PENDING
  RECEIVED
  SELECTED
  REJECTED
}

enum POStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum GRNStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum UnitOfMeasure {
  NOS
  KG
  TONNES
  METERS
  SQ_METERS
  CU_METERS
  LITERS
  BAGS
  BUNDLES
  ROLLS
  SHEETS
  SETS
  BOXES
}

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  hashedPassword String
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  siteAssignments  UserSiteAssignment[]
  indentsCreated   MaterialIndent[]     @relation("IndentCreator")
  approvalsGiven   IndentApproval[]
  assignedIndents  MaterialIndent[]     @relation("AssignedPTM")
  assignedByHoP    MaterialIndent[]     @relation("AssignedByHoP")
  rfqsCreated      RFQ[]
  posCreated       PurchaseOrder[]
  posApproved      PurchaseOrder[] @relation("POApprover")
  grnsCreated      GoodsReceipt[]

  @@map("users")
}

model UserSiteAssignment {
  id     String @id @default(cuid())
  userId String
  siteId String
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, siteId, role])
  @@map("user_site_assignments")
}

model Site {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  address   String?
  city      String?
  state     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAssignments  UserSiteAssignment[]
  approvalWorkflow ApprovalWorkflowStep[]
  inventory        Inventory[]
  indents          MaterialIndent[]
  goodsReceipts    GoodsReceipt[]

  @@map("sites")
}

model ApprovalWorkflowStep {
  id        String @id @default(cuid())
  siteId    String
  stepOrder Int
  role      Role

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([siteId, stepOrder])
  @@unique([siteId, role])
  @@map("approval_workflow_steps")
}

model Material {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  description String?
  category    String
  unit        UnitOfMeasure
  hsnCode     String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  inventory   Inventory[]
  indentItems IndentItem[]
  rfqItems    RFQItem[]
  quoteItems  QuoteItem[]
  poItems     POItem[]
  grnItems    GRNItem[]

  @@map("materials")
}

model Inventory {
  id         String  @id @default(cuid())
  siteId     String
  materialId String
  quantity   Decimal @default(0) @db.Decimal(12, 3)

  site     Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([siteId, materialId])
  @@map("inventory")
}

model MaterialIndent {
  id                  String       @id @default(cuid())
  indentNumber        String       @unique
  siteId              String
  createdById         String
  status              IndentStatus @default(DRAFT)
  remarks             String?
  requiredDate        DateTime?
  priority            String       @default("NORMAL")
  currentApprovalStep Int          @default(0)
  assignedToId        String?
  assignedById        String?
  assignedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  site           Site             @relation(fields: [siteId], references: [id])
  createdBy      User             @relation("IndentCreator", fields: [createdById], references: [id])
  assignedTo     User?            @relation("AssignedPTM", fields: [assignedToId], references: [id])
  assignedBy     User?            @relation("AssignedByHoP", fields: [assignedById], references: [id])
  items          IndentItem[]
  approvals      IndentApproval[]
  rfqs           RFQ[]
  purchaseOrders PurchaseOrder[]

  @@index([siteId, status])
  @@index([createdById])
  @@index([assignedToId])
  @@map("material_indents")
}

model IndentItem {
  id              String        @id @default(cuid())
  indentId        String
  materialId      String
  quantity        Decimal       @db.Decimal(12, 3)
  unit            UnitOfMeasure
  purposeOfUse    String?
  remarks         String?
  stockAtCreation Decimal       @default(0) @db.Decimal(12, 3)

  indent   MaterialIndent @relation(fields: [indentId], references: [id], onDelete: Cascade)
  material Material       @relation(fields: [materialId], references: [id])

  @@map("indent_items")
}

model IndentApproval {
  id                String         @id @default(cuid())
  indentId          String
  userId            String
  stepOrder         Int
  role              Role
  action            ApprovalAction
  remarks           String?
  inventorySnapshot Json?
  createdAt         DateTime       @default(now())

  indent MaterialIndent @relation(fields: [indentId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id])

  @@index([indentId])
  @@map("indent_approvals")
}

model Vendor {
  id            String  @id @default(cuid())
  name          String
  code          String  @unique
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  state         String?
  gstNumber     String?
  panNumber     String?
  bankName      String?
  bankAccountNo String?
  bankIfscCode  String?
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories     VendorCategory[]
  rfqVendors     RFQVendor[]
  quotes         VendorQuote[]
  purchaseOrders PurchaseOrder[]

  @@map("vendors")
}

model VendorCategory {
  id       String @id @default(cuid())
  vendorId String
  category String

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, category])
  @@map("vendor_categories")
}

model RFQ {
  id          String    @id @default(cuid())
  rfqNumber   String    @unique
  indentId    String
  createdById String
  status      RFQStatus @default(DRAFT)
  dueDate     DateTime?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  indent    MaterialIndent @relation(fields: [indentId], references: [id])
  createdBy User           @relation(fields: [createdById], references: [id])
  items     RFQItem[]
  vendors   RFQVendor[]
  quotes    VendorQuote[]

  @@index([indentId])
  @@map("rfqs")
}

model RFQItem {
  id         String        @id @default(cuid())
  rfqId      String
  materialId String
  quantity   Decimal       @db.Decimal(12, 3)
  unit       UnitOfMeasure
  remarks    String?

  rfq      RFQ      @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id])

  @@map("rfq_items")
}

model RFQVendor {
  id                String    @id @default(cuid())
  rfqId             String
  vendorId          String
  accessToken       String    @unique
  sentAt            DateTime?
  sentVia           String?
  emailedAt         DateTime?
  quoteSubmittedAt  DateTime?

  rfq    RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor Vendor @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@index([accessToken])
  @@map("rfq_vendors")
}

model VendorQuote {
  id          String      @id @default(cuid())
  rfqId       String
  vendorId    String
  quoteNumber String?
  status      QuoteStatus @default(PENDING)
  totalAmount Decimal?    @db.Decimal(14, 2)
  validUntil  DateTime?
  remarks     String?
  receivedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  rfq    RFQ         @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  vendor Vendor      @relation(fields: [vendorId], references: [id])
  items  QuoteItem[]

  @@unique([rfqId, vendorId])
  @@map("vendor_quotes")
}

model QuoteItem {
  id         String        @id @default(cuid())
  quoteId    String
  materialId String
  quantity   Decimal       @db.Decimal(12, 3)
  unit       UnitOfMeasure
  unitPrice  Decimal       @db.Decimal(14, 2)
  gstPercent Decimal?      @db.Decimal(5, 2)
  totalPrice Decimal       @db.Decimal(14, 2)
  remarks    String?

  quote    VendorQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  material Material    @relation(fields: [materialId], references: [id])

  @@map("quote_items")
}

model PurchaseOrder {
  id                 String    @id @default(cuid())
  poNumber           String    @unique
  indentId           String
  vendorId           String
  createdById        String
  status             POStatus  @default(DRAFT)
  totalAmount        Decimal   @db.Decimal(14, 2)
  gstAmount          Decimal?  @db.Decimal(14, 2)
  grandTotal         Decimal   @db.Decimal(14, 2)
  deliveryDate       DateTime?
  deliveryAddress    String?
  termsAndConditions String?
  remarks            String?
  approvedById       String?
  approvedAt         DateTime?
  rejectionReason    String?
  sentToVendorAt     DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  indent        MaterialIndent @relation(fields: [indentId], references: [id])
  vendor        Vendor         @relation(fields: [vendorId], references: [id])
  createdBy     User           @relation(fields: [createdById], references: [id])
  approvedBy    User?          @relation("POApprover", fields: [approvedById], references: [id])
  items         POItem[]
  goodsReceipts GoodsReceipt[]

  @@index([indentId])
  @@index([vendorId])
  @@map("purchase_orders")
}

model POItem {
  id         String        @id @default(cuid())
  poId       String
  materialId String
  quantity   Decimal       @db.Decimal(12, 3)
  unit       UnitOfMeasure
  unitPrice  Decimal       @db.Decimal(14, 2)
  gstPercent Decimal?      @db.Decimal(5, 2)
  totalPrice Decimal       @db.Decimal(14, 2)

  po       PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  material Material      @relation(fields: [materialId], references: [id])

  @@map("po_items")
}

model GoodsReceipt {
  id            String    @id @default(cuid())
  grnNumber     String    @unique
  poId          String
  siteId        String
  receivedById  String
  status        GRNStatus @default(DRAFT)
  receivedDate  DateTime  @default(now())
  vehicleNumber String?
  challanNumber String?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  po         PurchaseOrder @relation(fields: [poId], references: [id])
  site       Site          @relation(fields: [siteId], references: [id])
  receivedBy User          @relation(fields: [receivedById], references: [id])
  items      GRNItem[]

  @@index([poId])
  @@index([siteId])
  @@map("goods_receipts")
}

model GRNItem {
  id               String        @id @default(cuid())
  grnId            String
  materialId       String
  orderedQuantity  Decimal       @db.Decimal(12, 3)
  receivedQuantity Decimal       @db.Decimal(12, 3)
  acceptedQuantity Decimal       @db.Decimal(12, 3)
  rejectedQuantity Decimal       @default(0) @db.Decimal(12, 3)
  unit             UnitOfMeasure
  remarks          String?

  grn      GoodsReceipt @relation(fields: [grnId], references: [id], onDelete: Cascade)
  material Material     @relation(fields: [materialId], references: [id])

  @@map("grn_items")
}
